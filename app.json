{
  "expo": {
    "scheme": "surdomedia",
    "web": {
      "favicon": "./src/assets/banner.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-media-library",
        {
          "photosPermission": "Разрешите приложению сохранять видео в галерею",
          "savePhotosPermission": "Разрешите приложению сохранять видео",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "name": "Surdo.Media",
    "slug": "surdophone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "splash": {
      "image": "./src/assets/banner.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.surdo.media",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Приложению нужен доступ для сохранения видео в галерею",
        "NSPhotoLibraryAddUsageDescription": "Приложению нужно разрешение для сохранения видео"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.surdo.media",
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "fbe33f44-4494-4291-bf9f-2294f968b3ea"
      }
    },
    "owner": "vidkinomedia"
  }
}
